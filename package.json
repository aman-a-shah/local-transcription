{
  "name": "local-dictation-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Local Dictation — website, in-app dashboard, and shared design system.",
  "workspaces": [
    "packages/*",
    "web",
    "dashboard"
  ],
  "scripts": {
    "dev:web": "npm --workspace web run dev",
    "build:web": "npm --workspace web run build",
    "dev:dashboard": "npm --workspace dashboard run dev",
    "build:dashboard": "npm --workspace dashboard run build"
  },
  "engines": {
    "node": ">=18"
  }
}
